# .env.example - Variables de entorno opcionales para AI-MASTERY-COURSE
# Copia este archivo a .env y completa los valores que desees
# Ninguna de estas variables es obligatoria para el funcionamiento base

# --- API Keys Opcionales ---
# Hugging Face (para descargar modelos y datasets)
# HF_TOKEN=hf_xxx

# OpenAI (para ejemplos con GPT)
# OPENAI_API_KEY=sk-xxx

# Anthropic (para ejemplos con Claude)
# ANTHROPIC_API_KEY=sk-ant-xxx

# GitHub (para automatización con gh CLI)
# GITHUB_TOKEN=ghp_xxx

# --- Configuración ---
# LOG_LEVEL=INFO
# DATA_DIR=./datasets
# LOG_DIR=./logs
# UPDATE_BRANCH=auto-update
